<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Shattered Riffs</title>
    <link rel="shortcut icon" href="./assets/icons/logo.ico" type="image/x-icon">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- HEADER -->
    <header class="header">
        <div class="container header__content">
            <img src="https://w0.peakpx.com/wallpaper/413/118/HD-wallpaper-metallica-band-black-heavy-metal-music-rock-silver-thumbnail.jpg" alt="Logo" class="logo__img">
            <h1 class="logo">Shattered Riffs link</h1>
            <!-- Nav for desktop / hamburger for mobile -->
            <nav class="nav">
                <ul class="nav__list">
                    <li><a href="#events">Events</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#media">Media</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </nav>

        </div>
    </header>

    <main>

        <!-- HERO -->
        <section class="hero">
            <section>
                <div class="hero__overlay">
                <h2>Rock the Night</h2>
                <p>Upcoming Tour</p>
                <a href="#events" class="btn">View Events</a>
            </div>
            </section>
            
        </section>

        <!-- EVENTS -->
        <section id="events" class="events container">
            <h2>Upcoming Events</h2>

            <!-- Extra points: table -->
            <table class="events__table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>City</th>
                        <th>Venue</th>
                        <th>Tickets</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>15 May</td>
                        <td>Madrid</td>
                        <td>Sala Sol</td>
                        <td><button>Buy</button></td>
                    </tr>
                    <tr>
                        <td>18 May</td>
                        <td>Barcelona</td>
                        <td>Razzmatazz</td>
                        <td><button>Buy</button></td>
                    </tr>
                    <tr>
                        <td>22 May</td>
                        <td>Valencia</td>
                        <td>Moon Club</td>
                        <td><button>Buy</button></td>
                    </tr>
                </tbody>
            </table>
        </section>

        <!-- ABOUT -->
        <section id="about" class="about container">
            <h2>About the Band</h2>

            <div class="about__content">
               <section class="hero">
                <img src="https://thumbs.dreamstime.com/b/banda-de-rock-roll-multi%C3%A9tnica-joven-que-realiza-m%C3%BAsica-de-heavy-93486888.jpg" alt="Band photo">
                <div class="texto">
                    <h2>Who are we?</h2>
                    <p> Shattered Riffs is a high-energy rock band known for powerful live performances
                        and raw sound.</p>
                </div>                 
            </section>
            <section>
                 <h3>Our Influences</h3>
                    <ul>
                        <li>Classic Rock</li>
                        <li>Hard Rock</li>
                        <li>Alternative</li>
                    </ul>
            </section>
           
        </section>

        <!-- MEDIA -->
        <section id="media" class="media container">
            <h2>Multimedia</h2>

            <div class="media__grid">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTz5xKvxzSnE50hBV4RZ75JIM16ML7VHYSmHw&s" alt="">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTH7bNa9m54v39pfqteAeRngXAE73TuVpX2Gw&s" alt="">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSsMVpqc5AT5eLUZOSdusjuL5kaPrmIudsAeA&s" alt="">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSL33qOWk8mIgp4moGWXZ-CqgdnUpwY7iC_wQ&s" alt="">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQRdlcBK4q--wZbOwmW-daqOBVaSknAsmIp5g&s" alt="">
             
            </div>
        </section>

    </main>

    <!-- FOOTER -->

    <footer>
  <div class="footer-grid">
    <div class="col">
      <p>© <span id="year"></span> Shattered Riffs</p>
    </div>
    <div class="col">
      <h4>Enlaces</h4>
      <ul class="social">
                <li><a href="#">Instagram</a></li>
                <li><a href="#">Spotify</a></li>
                <li><a href="#">YouTube</a></li>
            </ul>
    </div>
    <div class="col">
      <h4>Contacto</h4>
      <p>correo@misitio.com</p>
      <p>+57 300 000 0000</p>
    </div>
</footer>

</body>
</html>
